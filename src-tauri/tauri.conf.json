{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "AppDrop",
    "version": "0.5.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "all": false, "open": true },
      "window": { "all": true },
      "app":    { "all": true },
      "http":   { "all": true, "scope": ["http://127.0.0.1:8742/**"] },
      "notification": { "all": true },
      "os":     { "all": true },
      "fs":     { "readFile": true, "writeFile": true, "scope": ["$APP/**","$HOME/.appdrop/**"] }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.appdrop.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "security": { "csp": null },
    "windows": [{
      "fullscreen": false,
      "resizable": true,
      "title": "AppDrop",
      "width": 1100,
      "height": 720,
      "minWidth": 800,
      "minHeight": 600,
      "decorations": true,
      "transparent": false
    }],
    "systemTray": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    }
  }
}
